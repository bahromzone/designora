# Copy this file to ".env" (cp env.example .env) and fill real values.
# NEVER commit the real .env file.

# ===== DATABASE =====
# Faqat PostgreSQL ishlatiladi. Drayver: psycopg2 (requirements.txt: psycopg2-binary).
# Local dev: postgresql+psycopg2://postgres:password@localhost:5432/designora
# Docker compose: postgresql+psycopg2://designora:designora@db:5432/designora
DATABASE_URL=postgresql+psycopg2://postgres:change-me@localhost:5432/designora

# ===== CORE =====
# Generate strong random values:
# python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=change-me-strong-random
ENVIRONMENT=development

# ===== SESSION =====
SESSION_SECRET_KEY=change-me-strong-random

# ===== JWT =====
JWT_SECRET_KEY=change-me-strong-random
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# ===== GOOGLE OAUTH (optional) =====
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ===== EMAIL (SMTP) =====
MAIL_USERNAME=your@email.com
MAIL_PASSWORD=your-app-password
MAIL_FROM=your@email.com
MAIL_PORT=587
MAIL_SERVER=smtp.gmail.com

# ===== reCAPTCHA =====
RECAPTCHA_SECRET_KEY=your-recaptcha-secret

# ===== CORS (comma-separated) =====
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8000,http://127.0.0.1:8000
